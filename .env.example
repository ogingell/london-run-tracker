# Get these from https://www.strava.com/settings/api
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret

# Set this to your deployed URL when hosting in the cloud
# e.g. https://london-run-tracker.fly.dev/api/auth/callback
# Leave unset for local development (defaults to localhost:5173)
STRAVA_REDIRECT_URI=

# Server config (optional)
PORT=3001
DB_PATH=/data/london-runs.db
